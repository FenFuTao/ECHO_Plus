<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ========== 标题栏：协议与连接（深色背景） ========== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@drawable/bg_protocol_title">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/protocol_title"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/protocolStatusBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:gravity="center"
                android:text="@string/protocol_status_disconnected"
                android:textColor="#FFB0BEC5"
                android:textSize="11sp"
                android:background="@drawable/bg_spinner_item" />
        </LinearLayout>

        <!-- ========== 卡片容器 ========== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- 数据引擎 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="12dp"
                android:paddingBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/protocol_data_engine"
                    android:textColor="#424242"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/protocolDocBtn"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_question_mark"
                    android:contentDescription="@string/protocol_doc_hint"
                    android:padding="4dp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/protocol_data_engine_desc"
                android:textColor="#9E9E9E"
                android:textSize="12sp"
                android:paddingBottom="12dp" />

            <!-- 分割线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="12dp" />

            <!-- 数据接口 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/protocol_data_interface"
                android:textColor="#424242"
                android:textSize="14sp"
                android:textStyle="bold"
                android:paddingBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/protocol_data_interface_desc"
                android:textColor="#9E9E9E"
                android:textSize="12sp"
                android:paddingBottom="8dp" />

            <!-- Spinner 下拉选择框 -->
            <Spinner
                android:id="@+id/protocolSpinner"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_spinner_item"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:popupBackground="@android:color/white"
                android:dropDownVerticalOffset="2dp"
                android:textSize="14sp"
                android:textColor="#424242" />

            <!-- 分割线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp" />

            <!-- 当前选项状态提示 -->
            <TextView
                android:id="@+id/protocolSelectionInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/protocol_select_hint"
                android:textColor="#757575"
                android:textSize="13sp"
                android:paddingTop="4dp"
                android:paddingBottom="8dp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
