<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:keepScreenOn="true"
    android:clipChildren="false">

    <LinearLayout
        android:id="@+id/workArea"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:baselineAligned="false"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout android:id="@+id/leftPanel"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="2" android:orientation="vertical"
            android:baselineAligned="false">

            <FrameLayout android:id="@+id/plotContainer"
                android:layout_width="match_parent" android:layout_height="0dp"
                android:layout_weight="1"
                android:background="#F5F5F5" android:padding="4dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_gravity="top|start" android:text="@string/plot_title"
                    android:textColor="#9E9E9E" android:textSize="12sp" />
            </FrameLayout>

            <FrameLayout android:id="@+id/hDivider"
                android:layout_width="match_parent" android:layout_height="14dp"
                android:background="#00000000">
                <View android:layout_width="match_parent" android:layout_height="3dp"
                    android:layout_gravity="center" android:background="#BDBDBD" />
            </FrameLayout>

            <FrameLayout android:id="@+id/outputContainer"
                android:layout_width="match_parent" android:layout_height="0dp"
                android:layout_weight="1"
                android:background="#1A1A1A" android:padding="4dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_gravity="top|start" android:text="@string/output_title"
                    android:textColor="#757575" android:textSize="12sp" />
            </FrameLayout>
        </LinearLayout>

        <FrameLayout android:id="@+id/vDivider"
            android:layout_width="14dp" android:layout_height="match_parent"
            android:background="#00000000">
            <View android:layout_width="3dp" android:layout_height="match_parent"
                android:layout_gravity="center" android:background="#BDBDBD" />
        </FrameLayout>

        <FrameLayout android:id="@+id/paramsContainer"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#FAFAFA" android:padding="4dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="top|start" android:text="@string/param_title"
                android:textColor="#9E9E9E" android:textSize="12sp" />
        </FrameLayout>
    </LinearLayout>

    <View android:id="@+id/scrimOverlay"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:background="#80000000" android:alpha="0"
        android:clickable="true" android:focusable="true"
        android:visibility="gone" />

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navViewA"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:clickable="true" android:focusable="true"
        android:visibility="gone"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/nav_drawer" />

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navViewB"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:clickable="true" android:focusable="true"
        android:visibility="gone"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/nav_drawer" />

    <FrameLayout
        android:id="@+id/menuBar"
        android:layout_width="48dp"
        android:layout_height="match_parent"
        android:elevation="50dp"
        android:clickable="true" android:focusable="true">

        <!-- 高亮指示器，置于按钮图层下方，主动匹配按钮位置 -->
        <View
            android:id="@+id/menuBarHighlight"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:background="@drawable/bg_menu_highlight"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- 顶部装饰圆角方形，不响应点击 -->
            <View
                android:id="@+id/menuBarDecoration"
                android:layout_width="40dp" android:layout_height="40dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_decoration"
                android:clickable="false" android:focusable="false"
                android:contentDescription="@null" />

            <ImageButton android:id="@+id/menuBarConnect"
                android:layout_width="40dp" android:layout_height="40dp"
                android:layout_marginTop="6dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/connect"
                android:scaleType="centerInside"
                android:src="@drawable/ic_connect_off" android:padding="6dp" />
            <ImageButton android:id="@+id/menuBarProtocol"
                android:layout_width="40dp" android:layout_height="40dp"
                android:layout_marginTop="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/protocol"
                android:scaleType="centerInside"
                android:src="@drawable/ic_protocol" android:padding="6dp" />
            <ImageButton android:id="@+id/menuBarCommand"
                android:layout_width="40dp" android:layout_height="40dp"
                android:layout_marginTop="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/command"
                android:scaleType="centerInside"
                android:src="@drawable/ic_command" android:padding="6dp" />
            <ImageButton android:id="@+id/menuBarControl"
                android:layout_width="40dp" android:layout_height="40dp"
                android:layout_marginTop="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/control"
                android:scaleType="centerInside"
                android:src="@drawable/ic_control" android:padding="6dp" />
            <Space android:layout_width="1dp" android:layout_height="0dp" android:layout_weight="1" />
            <ImageButton android:id="@+id/menuBarSetting"
                android:layout_width="40dp" android:layout_height="40dp"
                android:layout_marginBottom="12dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/settings"
                android:scaleType="centerInside"
                android:src="@drawable/ic_settings"
                android:padding="8dp" />
        </LinearLayout>
    </FrameLayout>

</FrameLayout>
